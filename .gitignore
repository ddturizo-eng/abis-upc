
# ABIS-UPC | .gitignore
# Ningun archivo o carpeta con informacion sensible o de configuracion debe
# ser versionado o subido al repositorio.


# ─── SECRETS Y SEGURIDAD (NUNCA AL REPO) ───────────────────────────────────
.env
*.jks
*.p12
*.keystore
*.pfx
*.key
*.pem
*.cert


# ─── FOTOS BIOMETRICAS (DATO SENSIBLE - Ley 1581/2012) ─────────────────────
static/fotos/
abis-biometric/static/fotos/
abis-backend/src/main/resources/static/fotos/


# ─── NATIVE SERVICE C# (.NET Framework 4.8) ────────────────────────────────
abis-native/**/bin/
abis-native/**/obj/
abis-native/**/*.exe
abis-native/**/*.pdb
abis-native/**/*.config


# ─── ENTORNOS PYTHON ────────────────────────────────────────────────────────
venv/
env/
.venv/
abis-biometric/venv/
__pycache__/
*.pyc
*.pyo
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage


# ─── COMPILADOS JAVA (MAVEN) ────────────────────────────────────────────────
target/
*.class
*.jar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
abis-backend/.mvn/
abis-biometric/.mvn/


# ─── LOGS ────────────────────────────────────────────────────────────────────
*.log
logs/


# ─── IDEs ────────────────────────────────────────────────────────────────────
.idea/
.vs/
*.iml
.vscode/
.settings/
.classpath
.project
*.swp
*~


# ─── SISTEMA OPERATIVO ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini


# ─── BASE DE DATOS (solo ignorar archivos temporales, no los DDL/DML) ──────
abis-database/**/*.tmp
abis-database/**/*.bak


# ─── DOCUMENTOS (solo ignorar temporales, no los .md) ──────────────────────
docs/**/*.aux
docs/**/*.log
docs/**/*.out
docs/**/*.toc
docs/**/*.synctex.gz
