# BASE DE DATOS ORACLE XE 18c
# Formato: jdbc:oracle:thin:@localhost:1521/XEPDB1
ABIS_DB_URL=jdbc:oracle:thin:@localhost:1521/XEPDB1
ABIS_DB_USER=abis
ABIS_DB_PASSWORD=12345

# SEGURIDAD JCA — KeyStore AES-256
# Generar UNA VEZ por maquina con CMD (no PowerShell):
#   "C:\Program Files\Java\jdk-24\bin\keytool.exe" -genseckey -alias abis-aes-key -keyalg AES -keysize 256 -storetype JCEKS -keystore abis-upc.jks
ABIS_KEYSTORE_PATH=C:/PROYECTOS P3/abis-upc/abis-upc.jks
ABIS_KEYSTORE_PASSWORD=
ABIS_AES_KEY_ALIAS=abis-aes-key

# CERTIFICADOS Y NOTIFICACIONES — Resend
ABIS_EMAIL_SERVICE_URL=http://localhost:8010
ABIS_EMAIL_SERVICE_TOKEN=
ABIS_RESEND_API_KEY=
ABIS_RESEND_FROM_EMAIL=ABIS UPC <onboarding@resend.dev>

# SERVIDOR JAVA (Javalin)
ABIS_SERVER_PORT=7000
ABIS_LOG_LEVEL=DEBUG

# URLS DE MICROSERVICIOS
BIOMETRIC_SERVICE_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8002
NATIVE_SERVICE_URL=http://localhost:8765

# FRONTEND
FRONTEND_PORT=5500
